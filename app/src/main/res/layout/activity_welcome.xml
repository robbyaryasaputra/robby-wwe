<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/hhh"
    tools:context=".pertemuan_3.WelcomeActivity">

  <View
      android:id="@+id/blurOverlay"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:background="#CC0F172A" /> <TextView
    android:id="@+id/tvWelcome"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="32dp"
    android:fontFamily="@font/opensans"
    android:gravity="center"
    android:text="Selamat Datang!!"
    android:textColor="@color/primary_violet"
    android:textSize="32sp"
    android:textStyle="bold"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintVertical_bias="0.4" />

  <TextView
      android:id="@+id/tvUserDisplay"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="8dp"
      android:fontFamily="@font/opensans"
      android:text="Halo, Username!"
      android:textColor="@color/text_white"
      android:textSize="18sp"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@+id/tvWelcome" />

  <TextView
      android:id="@+id/tvSubText"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="24dp"
      android:fontFamily="@font/opensans"
      android:text="Jadikan setiap gerakanmu lebih berarti bersama Move."
      android:textColor="@color/text_muted"
      android:textSize="14sp"
      android:gravity="center"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@+id/tvUserDisplay" />

</androidx.constraintlayout.widget.ConstraintLayout>