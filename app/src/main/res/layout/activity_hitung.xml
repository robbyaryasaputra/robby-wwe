<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#F4F9FF"
    tools:context=".pertemuan_2.HitungActivity">
    <TextView
        android:id="@+id/judulSegitiga"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1. Hitung Luas Segitiga"
        android:textStyle="bold"
        android:textSize="20sp"
        android:textColor="#0D47A1"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
    <EditText
        android:id="@+id/inputAlas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="50dp"
        android:hint="Masukkan Alas"
        android:inputType="numberDecimal"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/judulSegitiga" />

    <EditText
        android:id="@+id/inputTinggi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="50dp"
        android:hint="Masukkan Tinggi"
        android:inputType="numberDecimal"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/inputAlas" />

    <Button
        android:id="@+id/btnSegitiga"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hitung Segitiga"
        android:layout_marginTop="16dp"
        app:backgroundTint="#2196F3"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/inputTinggi"
        app:layout_constraintStart_toStartOf="parent" />
    <TextView
        android:id="@+id/judulKubus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2. Hitung Volume Kubus"
        android:textStyle="bold"
        android:textSize="20sp"
        android:textColor="#0D47A1"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/btnSegitiga"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/inputSisi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="50dp"
        android:hint="Masukkan Panjang Sisi"
        android:inputType="numberDecimal"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/judulKubus" />

    <Button
        android:id="@+id/btnKubus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hitung Kubus"
        android:layout_marginTop="16dp"
        app:backgroundTint="#0288D1"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/inputSisi"
        app:layout_constraintStart_toStartOf="parent" />
    <TextView
        android:id="@+id/teksHasil"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="60dp"
        android:text="Hasil Perhitungan"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1565C0"
        android:textAlignment="center"
        android:padding="16dp"
        android:background="#E3F2FD"
        android:elevation="2dp"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/btnKubus" />
</androidx.constraintlayout.widget.ConstraintLayout>